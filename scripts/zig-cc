#!/usr/bin/env sh
set -eu

zig_target() {
	case "${GOOS:-}/${GOARCH:-}" in
	linux/amd64)
		printf '%s\n' "x86_64-linux-gnu"
		;;
	linux/arm64)
		printf '%s\n' "aarch64-linux-gnu"
		;;
	windows/amd64)
		printf '%s\n' "x86_64-windows-gnu"
		;;
	windows/arm64)
		printf '%s\n' "aarch64-windows-gnu"
		;;
	darwin/amd64)
		printf '%s\n' "x86_64-macos"
		;;
	darwin/arm64)
		printf '%s\n' "aarch64-macos"
		;;
	*)
		printf 'unsupported CGO target: GOOS=%s GOARCH=%s\n' "${GOOS:-unset}" "${GOARCH:-unset}" >&2
		exit 2
		;;
	esac
}

if ! command -v zig >/dev/null 2>&1; then
	printf 'zig is required for CGO cross-compilation\n' >&2
	exit 127
fi

exec zig cc -target "$(zig_target)" "$@"
